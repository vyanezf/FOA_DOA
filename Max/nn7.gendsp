            {
                "box": {
                    "id": "obj-9",
                    "maxclass": "newobj",
                    "numinlets": 0,
                    "numoutlets": 1,
                    "outlettype": [ "" ],
                    "patching_rect": [ 906.0, 71.0, 28.0, 22.0 ],
                    "text": "in 5"
                }
            },
            {
                "box": {
                    "code": "// foa_features.genexpr\n// in5 = window multiplier (e.g. 0.5 = 1 sec, 1.0 = 2 sec, 2.0 = 4 sec)\n\nHistory cnt(0);\nHistory win_len_latched(96000); // latched win_len, safe default = 2 sec\n\nHistory bx(0), bx2(0);\nHistory by(0), by2(0);\nHistory bz(0), bz2(0);\nHistory sumW2(0), sumX2(0), sumY2(0), sumZ2(0);\n\nHistory f1(0),  f2(0),  f3(0),  f4(0),\n        f5(0),  f6(0),  f7(0),  f8(0),\n        f9(0), f10(0), f11(0), f12(0);\n\n// inlets\nin1; in2; in3; in4;\n// in5 = multiplier (0.0 to 1.0 → maps to e.g. 0.25–2 sec)\n\n// compute desired win_len from in5, clamped to safe range\ndesired_win = clamp(48000 * in5, 12000, 192000); // 0.25s to 4s\n\nIx = in1 * in4;\nIy = in1 * in2;\nIz = in1 * in3;\nMagI = sqrt(Ix*Ix + Iy*Iy + Iz*Iz) + 1e-12;\nux = Ix / MagI;\nuy = Iy / MagI;\nuz = Iz / MagI;\n\nbx += ux;   bx2 += ux*ux;\nby += uy;   by2 += uy*uy;\nbz += uz;   bz2 += uz*uz;\nsumW2 += in1*in1;\nsumX2 += in4*in4;\nsumY2 += in2*in2;\nsumZ2 += in3*in3;\ncnt += 1;\n\nif (cnt >= win_len_latched) {\n    mean_x = bx / cnt;\n    mean_y = by / cnt;\n    mean_z = bz / cnt;\n    var_x = bx2/cnt - mean_x*mean_x;  std_x = sqrt(max(var_x,0));\n    var_y = by2/cnt - mean_y*mean_y;  std_y = sqrt(max(var_y,0));\n    var_z = bz2/cnt - mean_z*mean_z;  std_z = sqrt(max(var_z,0));\n    R = sqrt(mean_x*mean_x + mean_y*mean_y + mean_z*mean_z);\n    rmsW = sqrt(sumW2/cnt) + 1e-12;\n    rmsX = sqrt(sumX2/cnt) + 1e-12;\n    rmsY = sqrt(sumY2/cnt) + 1e-12;\n    rmsZ = sqrt(sumZ2/cnt) + 1e-12;\n    log_rmsW = log(rmsW + 1);\n    rX_ratio = rmsX / rmsW;\n    rY_ratio = rmsY / rmsW;\n    rZ_ratio = rmsZ / rmsW;\n    psi = clamp(1.0 - R, 0, 1);\n\n    f1=mean_x;  f2=mean_y;   f3=mean_z;\n    f4=std_x;   f5=std_y;    f6=std_z;\n    f7=R;       f8=log_rmsW;\n    f9=rX_ratio; f10=rY_ratio;\n    f11=rZ_ratio; f12=psi;\n\n    // ✅ latch the NEW win_len only at reset boundary\n    win_len_latched = desired_win;\n\n    cnt=0;\n    bx=0;   bx2=0;\n    by=0;   by2=0;\n    bz=0;   bz2=0;\n    sumW2=0; sumX2=0; sumY2=0; sumZ2=0;\n}\n\nout1=f1;   out2=f2;   out3=f3;   out4=f4;\nout5=f5;   out6=f6;   out7=f7;   out8=f8;\nout9=f9;  out10=f10; out11=f11; out12=f12;",
                    "fontface": 0,
                    "fontname": "<Monospaced>",
                    "fontsize": 12.0,
